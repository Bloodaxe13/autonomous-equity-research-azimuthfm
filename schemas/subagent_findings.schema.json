{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://azimuth.local/schemas/subagent_findings.schema.json",
  "title": "SubagentFindings",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "facet",
    "ticker",
    "completed_at",
    "tool_calls_used",
    "findings",
    "not_found",
    "contradictions",
    "summary"
  ],
  "properties": {
    "facet": {
      "type": "string",
      "minLength": 1
    },
    "ticker": {
      "type": "string",
      "minLength": 1
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "tool_calls_used": {
      "type": "integer",
      "minimum": 0,
      "maximum": 20
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim",
          "data",
          "source_url",
          "source_tier",
          "source_title",
          "source_date",
          "retrieval_date",
          "confidence",
          "notes"
        ],
        "properties": {
          "claim": {"type": "string", "minLength": 1},
          "data": {},
          "source_url": {"type": "string", "format": "uri"},
          "source_tier": {"type": "integer", "minimum": 1, "maximum": 4},
          "source_title": {"type": "string", "minLength": 1},
          "source_date": {
            "anyOf": [
              {"type": "string", "format": "date"},
              {"type": "null"}
            ]
          },
          "retrieval_date": {"type": "string", "format": "date"},
          "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
          "notes": {"type": "string"}
        }
      }
    },
    "not_found": {
      "type": "array",
      "items": {"type": "string"}
    },
    "contradictions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "topic",
          "source_a",
          "source_a_claim",
          "source_b",
          "source_b_claim",
          "notes"
        ],
        "properties": {
          "topic": {"type": "string", "minLength": 1},
          "source_a": {"type": "string", "format": "uri"},
          "source_a_claim": {"type": "string", "minLength": 1},
          "source_b": {"type": "string", "format": "uri"},
          "source_b_claim": {"type": "string", "minLength": 1},
          "notes": {"type": "string"}
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  }
}
